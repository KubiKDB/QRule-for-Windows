<Window x:Class="QRuleW.Result.ResultCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Width" Value="58"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#F2F2F2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F02B2B2B" CornerRadius="12"
            BorderBrush="#20FFFFFF" BorderThickness="1"
            Padding="14,12" MaxWidth="320">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="PayloadText"
                       Foreground="#FFFFFF" FontSize="13"
                       TextWrapping="Wrap" MaxWidth="280"
                       Margin="2,0,2,12"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="OpenButton" Style="{StaticResource CardButton}" Click="OnOpen">
                    <StackPanel>
                        <TextBlock x:Name="OpenGlyph" FontFamily="Segoe MDL2 Assets" Text="&#xE774;"
                                   FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="OpenLabel" FontSize="11" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="CopyButton" Style="{StaticResource CardButton}" Click="OnCopy">
                    <StackPanel>
                        <TextBlock x:Name="CopyGlyph" FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;"
                                   FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CopyLabel" FontSize="11" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="ShareButton" Style="{StaticResource CardButton}" Click="OnShare">
                    <StackPanel>
                        <TextBlock x:Name="ShareGlyph" FontFamily="Segoe MDL2 Assets" Text="&#xE72D;"
                                   FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ShareLabel" FontSize="11" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="CloseButton" Style="{StaticResource CardButton}" Click="OnClose">
                    <StackPanel>
                        <TextBlock x:Name="CloseGlyph" FontFamily="Segoe MDL2 Assets" Text="&#xE711;"
                                   FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CloseLabel" FontSize="11" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
