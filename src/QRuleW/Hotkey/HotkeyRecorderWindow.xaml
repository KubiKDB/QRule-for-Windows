<Window x:Class="QRuleW.Hotkey.HotkeyRecorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#2B2B2B"
        Width="380">
    <StackPanel Margin="20">
        <TextBlock x:Name="HintText" Foreground="#D0D0D0" FontSize="13"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>

        <TextBlock x:Name="CurrentLabel" Foreground="#909090" FontSize="12" Margin="0,0,0,4"/>

        <Border Background="#1E1E1E" CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
            <TextBlock x:Name="ShortcutDisplay" Foreground="White" FontSize="16"
                       FontWeight="SemiBold" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock x:Name="ErrorText" Foreground="#FF7A7A" FontSize="12"
                   TextWrapping="Wrap" Visibility="Collapsed" Margin="0,2,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="RecordButton" MinWidth="130" Height="30" Margin="0,0,8,0" Click="OnRecord"/>
            <Button x:Name="SaveButton" MinWidth="80" Height="30" Margin="0,0,8,0" Click="OnSave"/>
            <Button x:Name="CancelButton" MinWidth="80" Height="30" Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
